# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sb_secret_xxxxxxxx  # service_role key

# 爬虫间隔(分钟)
CRAWL_INTERVAL=15

# 热度阈值
HEAT_THRESHOLD=100

# DeepSeek API (可选，LLM_ENABLED=true时生效)
LLM_ENABLED=true
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Firebase (推送用)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# 日志级别
LOG_LEVEL=INFO
